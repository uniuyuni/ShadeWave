{
    // IntelliSense を使用して利用可能な属性を学べます。
    // 既存の属性の説明をホバーして表示します。
    // 詳細情報は次を確認してください: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python デバッガー: 現在のファイル",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "env": {
                "ENABLE_PJRT_COMPATIBILITY": "1",
                "PYTORCH_MPS_HIGH_WATERMARK_RATIO": "0.0",
                "PYTORCH_ENABLE_MPS_FALLBACK": "1",
                "PYTORCH_MPS_FAST_MATH": "1",
                "KMP_DUPLICATE_LIB_OK": "FALSE",
                "DYLD_INSERT_LIBRARIES": "${workspaceFolder}/venv3.11.9/lib/python3.11/site-packages/torch/lib/libomp.dylib",
                "DYLD_FALLBACK_LIBRARY_PATH": "/usr/lib:/usr/local/lib:/opt/homebrew/lib:${env:DYLD_FALLBACK_LIBRARY_PATH}",
            },
            //"cwd": "${fileDirname}",
        },
        {
            "name": "Python デバッガー: main.py",
            "type": "debugpy",
            "request": "launch",
            "program": "main.py",
            "console": "integratedTerminal",
            "env": {
                "ENABLE_PJRT_COMPATIBILITY": "1",
                "PYTORCH_MPS_HIGH_WATERMARK_RATIO": "0.0",
                "PYTORCH_ENABLE_MPS_FALLBACK": "1",
                "PYTORCH_MPS_FAST_MATH": "1",
                "KMP_DUPLICATE_LIB_OK": "FALSE",
                //"DYLD_INSERT_LIBRARIES": "/opt/homebrew/opt/libomp/lib/libomp.dylib",
                "DYLD_INSERT_LIBRARIES": "venv3.11.9/lib/python3.11/site-packages/torch/lib/libomp.dylib",
                "DYLD_FALLBACK_LIBRARY_PATH": "/usr/lib:/usr/local/lib:/opt/homebrew/lib:${env:DYLD_FALLBACK_LIBRARY_PATH}",
            }
        }
    ]
}