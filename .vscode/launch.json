{
    // IntelliSense を使用して利用可能な属性を学べます
    // 既存の属性の説明をホバーして表示します
    // 詳細情報は次を確認してください: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python デバッガー: 現在のファイル (pixi)",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "python": "${workspaceFolder}/.pixi/envs/default/bin/python",
            "cwd": "${fileDirname}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/SAM3${pathSeparator}${env:PYTHONPATH}",
                "CONDA_PREFIX": "${workspaceFolder}/.pixi/envs/default",
                "OMP_DISPLAY_ENV": "FALSE",
                "KMP_WARNINGS": "0",
                "LIBOMP_VERBOSE": "0",
                "ENABLE_PJRT_COMPATIBILITY": "1",
                "PYTORCH_MPS_HIGH_WATERMARK_RATIO": "0.0",
                "PYTORCH_ENABLE_MPS_FALLBACK": "1",
                "PYTORCH_MPS_FAST_MATH": "1",
                "KMP_DUPLICATE_LIB_OK": "FALSE",
                "DYLD_INSERT_LIBRARIES": "${workspaceFolder}/.pixi/envs/default/lib/libomp.dylib",
                "DYLD_FALLBACK_LIBRARY_PATH": "${workspaceFolder}/.pixi/envs/default/lib:/usr/lib:/usr/local/lib:/opt/homebrew/lib:${env:DYLD_FALLBACK_LIBRARY_PATH}"
            }
        },
        {
            "name": "Python デバッガー: main.py (pixi)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "python": "${workspaceFolder}/.pixi/envs/default/bin/python",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/SAM3${pathSeparator}${env:PYTHONPATH}",
                "CONDA_PREFIX": "${workspaceFolder}/.pixi/envs/default",
                "OMP_DISPLAY_ENV": "FALSE",
                "KMP_WARNINGS": "0",
                "LIBOMP_VERBOSE": "0",
                "ENABLE_PJRT_COMPATIBILITY": "1",
                "PYTORCH_MPS_HIGH_WATERMARK_RATIO": "0.0",
                "PYTORCH_ENABLE_MPS_FALLBACK": "1",
                "PYTORCH_MPS_FAST_MATH": "1",
                "KMP_DUPLICATE_LIB_OK": "FALSE",
                "DYLD_INSERT_LIBRARIES": "${workspaceFolder}/.pixi/envs/default/lib/libomp.dylib",
                "DYLD_FALLBACK_LIBRARY_PATH": "${workspaceFolder}/.pixi/envs/default/lib:/usr/lib:/usr/local/lib:/opt/homebrew/lib:${env:DYLD_FALLBACK_LIBRARY_PATH}"
            }
        }
    ]
}
