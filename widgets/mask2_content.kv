
#:import kvutils utils.kvutils

<Button>:
    background_down: ''
    background_color: [0.13, 0.23, 0.74, 1] if self.state == 'down' else [0.48, 0.48, 0.48, 1]

<Mask2CustomHeader>:
    size_hint_y: None
    ref_height: 10  # ここで縦幅を調整

<Mask2Item>:
    orientation: 'horizontal'
    size_hint_y: None
    ref_height: 24
    height: kvutils.dpi_scale_height(self.ref_height)
    canvas.before:
        Color:
            rgba: (0.2, 0.2, 0.6, 0.6) if self.active else (0, 0, 0, 0)
        Rectangle:
            pos: self.pos
            size: self.size

    # インデント用スペーサー（BoxLayoutなのでWidgetで代用、またはpaddingで調整）
    
    Label:
        text: root.text
        size_hint_x: 0.4
        halign: 'left'
        valign: 'center'
        font_size: '13sp'
        text_size: self.size
        # padding_x: 10 + root.indent * 20
        color: 1, 1, 1, 1

    Label:
        text: root.mask_op
        size_hint_x: 0.2
        font_size: '11sp'

    BoxLayout:
        size_hint_x: 0.4
        opacity: 1 if root.is_composit else 0
        disabled: not root.is_composit
        Button:
            text: '+'
            on_release: root.add_child('Add')
        Button:
            text: '-'
            on_release: root.add_child('Subtract')

    Button:
        text: 'x'
        size_hint_x: 0.1
        on_release: root.delete_item()
        background_color: 1, 0, 0, 1

<SelectableRecycleBoxLayout>:

<Mask2ContentPanel>:
    orientation: "vertical"
    size_hint_y: None
    height: self.minimum_height

    Button:
        text: "Add Layer"
        size_hint_y: None
        ref_height: 20
        height: kvutils.dpi_scale_height(self.ref_height)
        on_release: root.add_layer()

    Label:
        # コピー元選択モードのヒント(優先)か、選択中マスクの操作ヒントを表示する。
        # どちらも無いとき(空)は高さ0で非表示。
        text: "Tap a mask to copy from it (ESC to cancel)" if root.copy_mode else root.active_hint
        size_hint_y: None
        height: kvutils.dpi_scale_height(20) if (root.copy_mode or root.active_hint) else 0
        opacity: 1 if (root.copy_mode or root.active_hint) else 0
        font_size: '11sp'
        color: 1, 1, 0.4, 1

    RecycleView:
        id: mask2_rv
        viewclass: 'Mask2Item'
        do_scroll_y: False # Disable internal scroll
        scroll_type: ['bars', 'content']
        size_hint_y: None
        height: layout.minimum_height # Bind to layout height

        SelectableRecycleBoxLayout:
            id: layout
            orientation: 'vertical'
            default_size_hint: 1, None
            default_size: None, None
            size_hint_y: None
            height: self.minimum_height
