
#:import kvutils utils.kvutils

<HistoryCustomHeader>:
    size_hint_y: None
    ref_height: 10  # ここで縦幅を調整

<HistoryItem>:
    ref_height: 20
    height: kvutils.dpi_scale_height(self.ref_height)
    size_hint_y: None
    orientation: 'horizontal'
    
    canvas.before:
        Color:
            rgba: (0, 1, 1, 0.3) if self.selected else (0, 0, 0, 1)
        Rectangle:
            pos: self.pos
            size: self.size

    Label:
        text: root.col1_text
        size_hint_x: 0.5
        text_size: self.size
        halign: 'left'
        valign: 'middle'
        color: (.8, .8, .8, 1) if root.active else (.4, .4, .4, 1)
        font_size: '9pt'
        padding_x: '5dp'
        shorten: True
        shorten_from: 'right'

    Label:
        text: root.col2_text
        size_hint_x: 0.25
        text_size: self.size
        halign: 'right'
        valign: 'middle'
        color: (.8, .8, .8, 1) if root.active else (.4, .4, .4, 1)
        font_size: '9pt'

    Label:
        text: root.col3_text
        size_hint_x: 0.25
        text_size: self.size
        halign: 'right'
        valign: 'middle'
        color: (.8, .8, .8, 1) if root.active else (.4, .4, .4, 1)
        font_size: '9pt'
        padding_x: '5dp'

<SelectableRecycleBoxLayout>:

<HistoryContentPanel>:
    orientation: "vertical"
    size_hint_y: None
    height: self.minimum_height

    RecycleView:
        id: history_rv
        viewclass: 'HistoryItem'
        do_scroll_x: False
        scroll_type: ['bars', 'content']
        size_hint_y: None
        ref_height: 200 #layout.minimum_height

        SelectableRecycleBoxLayout:
            id: layout
            orientation: 'vertical'
            default_size_hint: 1, None
            default_size: None, None
            size_hint_y: None
            height: self.minimum_height
