
<TinyButton>:
    canvas.after:
        # 色の決定ロジック
        Color:
            rgba:
                self.bg_color_disabled if self.disabled else \
                (self.bg_color_down if self.state == 'down' else self.bg_color_normal)

        # ボタン列を入力欄になじませるため、通常時は面だけを描き、縁取りは描かない。
        Rectangle:
            pos: self.x, self.y
            size: self.width, self.height

        Color:
            rgba: 0.36, 0.36, 0.38, 1 if not self.disabled else 0.25
        Line:
            rectangle: [self.x + 0.5, self.y + 0.5, max(0, self.width - 1), max(0, self.height - 1)]
            width: 1

        Color:
            rgba: 0.62, 0.62, 0.64, 1 if not self.disabled else 0.35
        Triangle:
            points: self.triangle_points
