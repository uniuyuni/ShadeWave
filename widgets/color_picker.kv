
#:include widgets/param_slider.kv

<CWColorWheel>:
    pos_hint: {'center_x': .5, 'center_y': .5}
    size_hint: None, None
    ref_width: 130
    ref_height: 130

    Image:
        source: 'assets/color_wheel.png'

<CWColorPreview>:
    size_hint: None, None
    radius: [8]
    ref_width: 40
    ref_height: 20

    canvas:
        Color:
            rgba: self.color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: self.radius

<CWColorPicker>:
    orientation: 'vertical'
    spacing: 20
    radius: [0]
    size_hint: 1, None
    ref_height: 172
    pos_hint: {'center_x': 0.5, 'center_y': .5}

    BoxLayout:
        
        CWColorWheel:
            id: color_wheel

        BoxLayout:
            id: sliders_container
            orientation: 'vertical'
            pos_hint: {'center_x': .5, 'center_y': .52}

            CWColorPreview:
                id: preview
                color: root.get_current_color_rgb()

            ParamSlider:
                text: 'R:'
                label_width: 20
                ref_height: 24
                id: slider_red
                min: 0
                max: 255
                value: 127.5
                on_slider: root.on_slider_change_rgb()
                on_before_edit: root.on_slider_before_edit()
                on_after_edit: root.on_slider_after_edit()

            ParamSlider:
                text: 'G:'
                label_width: 20
                ref_height: 24
                id: slider_green
                min: 0
                max: 255
                value: 127.5
                on_slider: root.on_slider_change_rgb()
                on_before_edit: root.on_slider_before_edit()
                on_after_edit: root.on_slider_after_edit()

            ParamSlider:
                text: 'B:'
                label_width: 20
                ref_height: 24
                id: slider_blue
                min: 0
                max: 255
                value: 127.5
                on_slider: root.on_slider_change_rgb()
                on_before_edit: root.on_slider_before_edit()
                on_after_edit: root.on_slider_after_edit()

            ParamSlider:
                text: 'H:'
                label_width: 20
                ref_height: 24
                id: slider_hue
                min: 0
                max: 360
                value: 0
                on_slider: root.on_slider_change_hls()
                on_before_edit: root.on_slider_before_edit()
                on_after_edit: root.on_slider_after_edit()

            ParamSlider:
                text: 'L:'
                label_width: 20
                ref_height: 24
                id: slider_lum
                min: 0
                max: 100
                value: 50
                on_slider: root.on_slider_change_hls()
                on_before_edit: root.on_slider_before_edit()
                on_after_edit: root.on_slider_after_edit()

            ParamSlider:
                text: 'S:'
                label_width: 20
                ref_height: 24
                id: slider_sat
                min: 0
                max: 100
                value: 0
                on_slider: root.on_slider_change_hls()
                on_before_edit: root.on_slider_before_edit()
                on_after_edit: root.on_slider_after_edit()
