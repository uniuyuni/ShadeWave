
#:include widgets/float_input.kv
#:include widgets/multi_slider.kv
#:include widgets/tiny_button.kv
#:include widgets/define.kv

<RectangleToggleButton@MDRectangleFlatButton+MDToggleButton>:
    _no_ripple_effect: True
    background_normal: 'black'
    background_down: 0.3, 0.3, 0.3, 1
    line_color: 1, 1, 1, 0.8

<HeadLabel>:
    orientation: 'horizontal'
    size_hint_y: None
    ref_height: 18
    text: 'Label'
    enabled: self.active
    button_enabled: True

    RectangleToggleButton:
        id: toggle
        disabled: not root.button_enabled
        pos_hint: {'center_y': 0.5}
        size_hint: None, None
        ref_width: 12
        ref_height: 12
        state: 'down' if root.enabled else 'normal'
        on_state: root.press = self.state == 'down'
        on_state: root.active = self.state == 'down'
        on_release: root.release = self.state == 'down'

    MDLabel:
        text: root.text
        font_size: '10pt'
        halign: 'left'
        on_touch_down: root.on_label_touch_down(args[1]) if self.collide_point(*args[1].pos) else False
        #size_hint_y: None
        #ref_height: 18

<ParamBoxLayout@BoxLayout>:
    orientation: 'horizontal'
    size_hint_y: None
    ref_height: 22

<ParamLabel@MDLabel>:
    font_size: '9pt'
    halign: 'right'
    color: 'b0b0b0'
    size_hint_x: None
    ref_width: 100

<ParamSlider>:
    text: 'Label'
    orientation: 'horizontal'
    size_hint_y: None
    ref_height: 24
    label_width: 100
    for_float: False
    on_text: root.on_label_text()
    on_for_float: self.ids.input.set_float_mode(self.for_float)

    ParamLabel:
        id: label
        ref_width: self.parent.label_width
        width: self.parent.label_width
        
    MultiSlider:
        id: slider
        hint: False
        pos_hint: {'center_y': 0.5}
        size_hint_x: 1
        draw_from_anchor: True
        track_color_inactive: gray_color
        track_color_active:  dark_blue
        thumb_color: light_blue
        on_value: root.on_slider_value()
        on_touch_down: root.on_slider_touch_down(args[1])
        on_touch_up: root.on_slider_touch_up(args[1])

    ParamFloatInput:
        id: input
        halign: 'right'
        valign: 'middle'
        font_size: '9pt'
        multiline: False
        size_hint_x: None
        ref_width: 40
        for_float: root.for_float
        on_text_validate: root.on_input_text_validate()

    BoxLayout:
        orientation: 'vertical'
        size_hint_x: None
        ref_width: 15
        
        TinyButton:
            bg_color_down: 'black'
            on_press: root.on_button_press(root.ids['slider'].step)
        TinyButton:
            bg_color_down: 'black'
            on_press: root.on_button_press(-root.ids['slider'].step)
