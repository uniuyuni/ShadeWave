
<CollapsibleBox>:
    size_hint_y: None
    height: btn_header.height + scroll_view.height

    # Clickable header area
    CollapsibleHeader:
        id: btn_header
        size_hint_y: None
        ref_height: 20
        orientation: "horizontal"
        ref_layout_padding: 5
        on_press: root.toggle()
        canvas.before:
            Color:
                rgba: 0.12, 0.12, 0.12, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # Optional Icon
        Image:
            source: root.icon_source
            size_hint: None, None
            ref_width: root.icon_ref_size if root.icon else 0
            ref_height: root.icon_ref_size if root.icon else 0
            pos_hint: {'center_y': .5}
            opacity: 1 if root.icon else 0
            allow_stretch: True
            keep_ratio: True
            mipmap: True

        # Title
        Label:
            text: root.title
            halign: "left"
            valign: "middle"
            text_size: self.size
            font_size: '10pt'
            bold: True
            color: 0.8, 0.8, 0.8, 1
            size_hint_x: 1 # Ensure it expands

        # Expand/Collapse Arrow
        Label:
            text: "-" if root.is_expanded else "+"
            halign: "center"
            valign: "middle"
            size_hint_x: None
            ref_width: 20
            font_size: '16sp'
            bold: True
            color: 0.7, 0.7, 0.7, 1

    # ScrollViewで中身をラップ（これが肝）
    ScrollView:
        id: scroll_view
        size_hint_y: None
        height: root.content_height if root.is_expanded else 0  # 開閉制御
        opacity: 1 if root.is_expanded else 0
        do_scroll_x: False
        bar_width: dp(4)
        scroll_y: 1  # 上端固定
        
        BoxLayout:
            id: content
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            padding: dp(5)
