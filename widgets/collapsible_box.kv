
<CollapsibleBox>:
    size_hint_y: None
    height: self.minimum_height if self.is_expanded else btn_header.height

    # Clickable header area
    Button:
        id: btn_header
        size_hint_y: None
        ref_height: 20
        background_color: 0.2, 0.2, 0.2, 1
        on_press: root.toggle()
             
        BoxLayout:
            pos: self.parent.pos
            size: self.parent.size
            orientation: "horizontal"
            ref_padding: 5

            # Optional Icon
            Image:
                source: root.icon
                size_hint_x: None
                width: self.height if root.icon else 0
                opacity: 1 if root.icon else 0
                allow_stretch: True

            # Title
            Label:
                text: root.title
                halign: "left"
                valign: "middle"
                text_size: self.size
                font_size: '10pt'
                bold: True
                color: 0.8, 0.8, 0.8, 1
                size_hint_x: 1 # Ensure it expands

            # Expand/Collapse Arrow
            Label:
                text: "-" if root.is_expanded else "+"
                halign: "center"
                valign: "middle"
                size_hint_x: None
                ref_width: 20
                font_size: '16sp'
                bold: True
                color: 0.7, 0.7, 0.7, 1

    # ScrollViewで中身をラップ（これが肝）
    ScrollView:
        id: scroll_view
        size_hint_y: None
        height: root.content_height if root.is_expanded else 0  # 開閉制御
        do_scroll_x: False
        bar_width: dp(4)
        scroll_y: 1  # 上端固定
        
        BoxLayout:
            id: content
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            padding: dp(5)

    #BoxLayout:
    #    id: content
    #    orientation: "vertical"
    #    size_hint_y: None
    #    height: self.minimum_height if root.is_expanded else 0
    #    opacity: 1 if root.is_expanded else 0
    #    #disabled: not root.is_expanded
    #    clip: True
