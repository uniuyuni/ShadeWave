
<ViewerWidget>:
    viewclass: 'ThumbnailCard'
    scroll_type: ['bars', 'content']
    bar_width: 0.008 * self.width
    scroll_wheel_distance: 0.1 * self.width
    
    RecycleGridLayout:
        cols: root.cols
        default_size_hint: None, 1
        default_size: root.card_width, None
        size_hint_x: None
        width: self.minimum_width
        ref_layout_padding: 6
