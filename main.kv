                        id: geometry
                        icon_source: 'assets/Geometry.png'

                        ScrollView:
                            bar_width: 10
                            scroll_type: ['bars', 'content']

                            MDBoxLayout:
                                orientation: "vertical"
                                size_hint_y: None
                                height: self.minimum_height
                                md_bg_color: dark_color
                                ref_padding: 4


                                HeadLabel:
                                    id: switch_rotation
                                    text: ' Rotation'
                                    button_enabled: False

                                ParamSlider:
                                    id: slider_rotation
                                    text: "Angle"
                                    min: -45.0
                                    max: 45.0
                                    value: 0
                                    step: 0.1
                                    for_float: True
                                    on_slider: root.apply_effects_lv(0, 'geometry')
                                    on_slider: root.apply_effects_lv(0, 'crop')
                                    on_before_edit:
                                        root.begin_history_effect_ctrl(0, 'geometry')
                                        root.begin_rotation_crop_preview()
                                    on_after_edit:
                                        root.end_rotation_crop_preview()
                                        root.end_history_effect_ctrl(0, 'geometry')

                                VSpacer:
                                
                                ParamBoxLayout:

                                    HSpacer:
                                        ref_width: 100
                                    Button:
                                        pos_hint: {'center_x': .5, 'center_y': .5}
                                        ref_height: 20
                                        text: "L"
                                        on_press:
                                            root.begin_history_effect_ctrl(0, 'geometry')
                                            root.set_effect_param(0, 'geometry', 90)
                                            root.apply_effects_lv(0, 'crop')
                                            root.end_history_effect_ctrl(0, 'geometry')
                                    Button:
                                        pos_hint: {'center_x': .5, 'center_y': .5}
                                        ref_height: 20
                                        text: "R"
                                        on_press:
                                            root.begin_history_effect_ctrl(0, 'geometry')
                                            root.set_effect_param(0, 'geometry', -90)
                                            root.apply_effects_lv(0, 'crop')
                                            root.end_history_effect_ctrl(0, 'geometry')
                                    Button:
                                        pos_hint: {'center_x': .5, 'center_y': .5}
                                        ref_height: 20
                                        text: "H"
                                        on_press:
                                            root.begin_history_effect_ctrl(0, 'geometry')
                                            root.set_effect_param(0, 'geometry', 'hflip')
                                            root.apply_effects_lv(0, 'crop')
                                            root.end_history_effect_ctrl(0, 'geometry')
                                    Button:
                                        pos_hint: {'center_x': .5, 'center_y': .5}
                                        ref_height: 20
                                        text: "V"
                                        on_press:
                                            root.begin_history_effect_ctrl(0, 'geometry')
                                            root.set_effect_param(0, 'geometry', 'vflip')
                                            root.apply_effects_lv(0, 'crop')
                                            root.end_history_effect_ctrl(0, 'geometry')

                                VSeparator:

                                HeadLabel:
                                    text: " Crop"
                                    button_enabled: False

                                ParamBoxLayout:
                                    ParamLabel:
                                        text: "Crop"
                                    HSpacer:
                                        size_hint_x: 0.5
                                    ParamChip:
                                        type: 'assist'
                                        id: button_crop_reset
                                        size_hint_x: None
                                        ref_width: 60
                                        on_release: root.apply_crop_button_action('reset')
                                        ParamChipText:
                                            text: "Reset"

                                ParamBoxLayout:
                                    ParamLabel:
                                        text: "Auto Crop"
                                    HSpacer:
                                        size_hint_x: 0.5
                                    ParamChip:
                                        type: 'assist'
                                        id: button_crop_auto
                                        size_hint_x: None
                                        ref_width: 60
                                        on_release: root.apply_crop_button_action('auto')
                                        ParamChipText:
                                            text: "Crop"

                                ParamBoxLayout:
                                    ParamLabel:
                                        text: "Aspect Ratio"
                                    HSpacer:
                                        size_hint_x: 0.15
                                    ParamSpinner:
                                        id: spinner_acpect_ratio
                                        values: ["None", "1 / 1", "5 / 4", "3 / 2", "4 / 3", "16 / 9", "1.414 / 1", "148 / 100"]
                                        on_value:
                                            root.begin_history_effect_ctrl(0, 'crop')
                                            root.apply_effects_lv(0, 'crop')
                                            root.end_history_effect_ctrl(0, 'crop')

                                VSeparator:

