                                    on_slider: root.apply_effects_lv(3, 'mask2')
                                    on_before_edit: root.begin_history_effect_ctrl(3, 'mask2')
                                    on_after_edit: root.end_history_effect_ctrl(3, 'mask2')

                                AnchorLayout:
                                    anchor_x: 'right'
                                    anchor_y: 'center'
                                    size_hint_y: None
                                    ref_height: 24

                                    MDGridLayout:
                                        size_hint: None, None
                                        ref_width: 256
                                        ref_height: 20
                                        cols: 2
                                        ref_spacing: 2

                                        ParamLabel:
                                            text: "Polyline Fill"
                                            ref_width: 128
                                        ParamCheckBox:
                                            id: checkbox_mask2_polyline_fill
                                            active: True
                                            on_press: root.begin_history_effect_ctrl(3, 'mask2')
                                            on_active: root.apply_effects_lv(3, 'mask2')
                                            on_release: root.end_history_effect_ctrl(3, 'mask2')

                                VSeparator:

                                HeadLabel:
                                    id: switch_mask2_face
                                    text: ' Face'
                                    on_press: root.begin_history_effect_ctrl(3, 'mask2')
                                    on_active: root.apply_effects_lv(3, 'mask2')
                                    on_release: root.end_history_effect_ctrl(3, 'mask2')

                                AnchorLayout:
                                    anchor_x: 'right'
                                    anchor_y: 'center'
                                    size_hint_y: None
                                    ref_height: 44

                                    MDGridLayout:
                                        id: grid_mask2_face
                                        size_hint: None, None
                                        cols: 6
                                        width: self.minimum_width
                                        height: self.minimum_height
                                        spacing: dp(4)

                                        ParamLabel:
                                            text: "Face"
                                            ref_width: 44
                                        ParamCheckBox:
                                            id: checkbox_mask2_face_face
                                            active: True
                                            on_press: root.begin_history_effect_ctrl(3, 'mask2')
                                            on_active: root.apply_effects_lv(3, 'mask2')
                                            on_release: root.end_history_effect_ctrl(3, 'mask2')
                                        ParamLabel:
                                            text: "Brows"
                                            ref_width: 44
                                        ParamCheckBox:
                                            id: checkbox_mask2_face_brows
                                            active: True
                                            on_press: root.begin_history_effect_ctrl(3, 'mask2')
                                            on_active: root.apply_effects_lv(3, 'mask2')
                                            on_release: root.end_history_effect_ctrl(3, 'mask2')
                                        ParamLabel:
                                            text: "Eyes"
                                            ref_width: 44
                                        ParamCheckBox:
                                            id: checkbox_mask2_face_eyes
                                            active: True
                                            on_press: root.begin_history_effect_ctrl(3, 'mask2')
                                            on_active: root.apply_effects_lv(3, 'mask2')
                                            on_release: root.end_history_effect_ctrl(3, 'mask2')
                                        ParamLabel:
                                            text: "Nose"
                                            ref_width: 44
                                        ParamCheckBox:
                                            id: checkbox_mask2_face_nose
                                            active: True
                                            on_press: root.begin_history_effect_ctrl(3, 'mask2')
                                            on_active: root.apply_effects_lv(3, 'mask2')
                                            on_release: root.end_history_effect_ctrl(3, 'mask2')
                                        ParamLabel:
                                            text: "Mouth"
                                            ref_width: 44
                                        ParamCheckBox:
                                            id: checkbox_mask2_face_mouth
                                            active: True
                                            on_press: root.begin_history_effect_ctrl(3, 'mask2')
                                            on_active: root.apply_effects_lv(3, 'mask2')
                                            on_release: root.end_history_effect_ctrl(3, 'mask2')
                                        ParamLabel:
                                            text: "Lips"
                                            ref_width: 44
                                        ParamCheckBox:
                                            id: checkbox_mask2_face_lips
                                            active: True
                                            on_press: root.begin_history_effect_ctrl(3, 'mask2')
                                            on_active: root.apply_effects_lv(3, 'mask2')
                                            on_release: root.end_history_effect_ctrl(3, 'mask2')

                    IconTabbedPanelItem:
                        text: 'Li'
                        icon_source: 'assets/Liquify.png'

                        ScrollView:
                            bar_width: 10
                            scroll_type: ['bars', 'content']

                            MDBoxLayout:
                                orientation: "vertical"
                                size_hint_y: None
                                height: self.minimum_height
                                md_bg_color: dark_color
                                ref_padding: 4

                                HeadLabel:
                                    id: switch_distortion
                                    text: ' Distortion'
                                    on_press: root.begin_history_effect_ctrl(1, 'distortion')
                                    on_active: root.apply_effects_lv(1, 'distortion')
                                    on_release: root.end_history_effect_ctrl(1, 'distortion')

                                VSpacer:

                                ParamBoxLayout:

                                    HSpacer:
                                        ref_width: 100

                                    DistortionEffectButton:
                                        text: "Warp"
                                        state: 'down'
                                        on_press: root.set_effect_param(1, 'distortion', 'forward_warp')
                                    
                                    DistortionEffectButton:
                                        text: "Bulge"
                                        on_press: root.set_effect_param(1, 'distortion', 'bulge')
                                    
                                    DistortionEffectButton:
                                        text: "Pinch"
                                        on_press: root.set_effect_param(1, 'distortion', 'pinch')
                                    
                                    DistortionEffectButton:
                                        text: "Swirl"
                                        on_press: root.set_effect_param(1, 'distortion', 'swirl')

                                    DistortionEffectButton:
                                        text: "Restore"
                                        on_press: root.set_effect_param(1, 'distortion', 'restore')

                                VSpacer:

                                ParamSlider:
                                    id: slider_distortion_brush_size
                                    text: "Brush Size"
                                    min: 10
                                    max: 1000
                                    value: 300
                                    step: 1
                                    on_slider: root.apply_effects_lv(1, 'distortion')
                                    on_before_edit: root.begin_history_effect_ctrl(1, 'distortion')
                                    on_after_edit: root.end_history_effect_ctrl(1, 'distortion')
                                ParamSlider:
                                    id: slider_distortion_strength
                                    text: "Strength"
                                    min: 1
                                    max: 100
                                    value: 50
                                    step: 1
                                    on_slider: root.apply_effects_lv(1, 'distortion')
                                    on_before_edit: root.begin_history_effect_ctrl(1, 'distortion')
                                    on_after_edit: root.end_history_effect_ctrl(1, 'distortion')

                                ParamBoxLayout:
                                    ParamLabel:
                                        text: "Paint"
                                    HSpacer:
                                        size_hint_x: 0.5
                                    ParamChip:
                                        type: 'assist'
                                        id: button_distortion_reset
                                        size_hint_x: None
                                        ref_width: 60
                                        on_press: root.begin_history_effect_ctrl(1, 'distortion')
                                        on_press: root.apply_effects_lv(1, 'distortion')
                                        on_release: root.end_history_effect_ctrl(1, 'distortion')
                                        ParamChipText:
                                            text: "Reset"

        ViewerWidget:
            id: viewer
            size_hint_y: None
            ref_height: 160
            do_scroll_x: True
            do_scroll_y: False
