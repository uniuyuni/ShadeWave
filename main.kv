                                    on_press: root.begin_history_effect_ctrl(0, 'geometry')
                                    on_active: root.apply_effects_lv(0, 'geometry')
                                    on_release: root.end_history_effect_ctrl(0, 'geometry')

                                ParamBoxLayout:

                                    HSpacer:
                                        ref_width: 100
