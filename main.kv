                                        on_press: root.set_effect_param(1, 'distortion', 'forward_warp')
                                    
                                    DistortionEffectButton:
                                        text: "Bulge"
                                        on_press: root.set_effect_param(1, 'distortion', 'bulge')
                                    
                                    DistortionEffectButton:
                                        text: "Pinch"
                                        on_press: root.set_effect_param(1, 'distortion', 'pinch')
                                    
                                    DistortionEffectButton:
                                        text: "Swirl"
                                        on_press: root.set_effect_param(1, 'distortion', 'swirl')

