
#:include widgets/param_slider.kv
#:include widgets/separator.kv
#:include widgets/spacer.kv
#:include widgets/viewer.kv
#:include widgets/histogram.kv
#:include widgets/metainfo.kv
#:include widgets/color_picker.kv
#:include widgets/export_dialog.kv
#:include widgets/hover_spinner.kv
#:include widgets/curve.kv
#:include widgets/mask2_content.kv
#:include widgets/history_content.kv
#:include widgets/collapsible_box.kv
#:include widgets/compact_switch.kv
#:include widgets/define.kv
#:import iconutils utils.iconutils

<DistortionEffectButton@ToggleButton>:
    group: 'effect'
    font_size: '9pt'
    pos_hint: {'center_x': .5, 'center_y': .5}
    ref_height: 20

<ParamChip@MDChip>:
    type: 'filter'
    pos_hint: {"center_x": .5, "center_y": .5}
    size_hint_y: None
    ref_height: 20
    radius: 40
    line_color: 'grey'

<ParamChipText@MDChipText>:
    font_size: '9pt'
    color: 'b0b0b0'

<ParamSwitch@CompactSwitch>:
    pos_hint: {'center_y': .5}
    size_hint: None, None
    ref_width: 40
    ref_height: 20

<ParamCheckBox@ModernCheckBox>:
    pos_hint: {'center_y': .5}
    size_hint: None, None
    ref_width: 20
    ref_height: 20
    active: False

<MainSpinnerOption@SpinnerOption>:
    size_hint_y: None
    height: dp(20)

<ParamSpinner@HoverSpinner>:
    pos_hint: {'center_x': .5, 'center_y': .5}
    size_hint: 0.55, None
    ref_height: 20
    font_size: '9pt'
    #option_cls: "MainSpinnerOption"

<IconTabbedPanelItem@TabbedPanelItem>:
    icon_source: ''
    text: ''
    background_color: tabbed_panel_color
    background_down: tabbed_panel_down
    canvas.after:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.center_x - (self.height * 0.7) / 2, self.center_y - (self.height * 0.7) / 2
            size: self.height * 0.7, self.height * 0.7
            source: iconutils.variant_source(root.icon_source, self.height * 0.7)

<TextTabbedPanelItem@TabbedPanelItem>:
    text: ''
    background_color: tabbed_panel_color
    background_down: tabbed_panel_down

<CurveTabbedPanel@TabbedPanel>:
    size_hint: None, None
    width: self.parent.width
    height: self.parent.width
    ref_tab_width: 70
    ref_tab_height: 20
    ref_padding: 8
    do_default_tab: False
    on_kv_post: self.switch_to(root.tab_list[0]) if root.tab_list else None

<SelectableListItem@OneLineListItem>:
    on_release: app.item_selected(self.text)

<WaitInfo@MDLabel>:
    font_size: '10pt'
    valign: 'middle'
    halign: 'right'
    color: 'b0b0b0'
    size_hint_y: None
    ref_height: 18

<IconButton@ButtonBehavior+Image>:
    icon_source: ''
    source: iconutils.variant_source(root.icon_source, min(self.width, self.height))
    keep_ratio: True
    mipmap: True
    background_normal: 'gray'
    md_bg_color: 'gray'

<IconToggleButton@MDIconButton+ToggleButtonBehavior>:
    _no_ripple_effect: True
    canvas.before:
        Color:
            rgba: [0.4, 0.4, 0.4, 1] if self.state == 'normal' else [1, 1, 1, 1]
        Line:
            rectangle: [self.x, self.y, self.width, self.height]
            width: 1   

<MainWidget>:
    loading: False
    preview_valid_rect: [0, 0, 100, 100]

    BoxLayout:
        orientation: 'vertical'

        BoxLayout:
            orientation: 'horizontal'

            ScrollView:
                size_hint_x: 0.2
                do_scroll_x: False
                bar_width: 10
                scroll_type: ['bars', 'content']

                BoxLayout:
                    id: info
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    ref_margin: 8
                    ref_spacing: 8

                    CollapsibleBox:
                        title: " Histogram"
                        icon: "assets/Histogram.png"
                        is_expanded: True
                        
                        BoxLayout:
                            orientation: "vertical"
                            size_hint_y: None
                            height: self.minimum_height

                            HistogramWidget:
                                id: histogram
                                size_hint: 1, None
                                ref_height: 128-32
                                ref_padding: 4
                                canvas:
                                    Color:
                                        rgba: dark_color
                                    Rectangle:
                                        size: self.size
                                        pos: self.pos
                            
                            VSpacer:
                                ref_height: 4
                            
                            BoxLayout:
                                orientation: 'horizontal'
                                size_hint_y: None
                                ref_height: 22
                                
                                IconToggleButton:
                                    id: toggle_underexposure
                                    icon: 'arrow-bottom-left-bold-box'
                                    font_size: '8pt'
                                    icon_size: '21dp'
                                    size_hint: None, None
                                    ref_width: 30
                                    ref_height: 22
                                    ref_padding: 8, 4, 8, 6
                                    on_state: root.start_draw_image()

                                HSpacer:
                                    ref_width: 4

                                IconToggleButton:
                                    id: toggle_overexposure
                                    icon: 'arrow-top-right-bold-box-outline'
                                    font_size: '8pt'
                                    icon_size: '21dp'
                                    size_hint: None, None
                                    ref_width: 30
                                    ref_height: 22
                                    ref_padding: 8, 4, 8, 6
                                    on_state: root.start_draw_image()

                    CollapsibleBox:
                        title: " Metadata"
                        icon: "assets/Metadata.png"
                        is_expanded: True
                        
                        ScrollView:
                            do_scroll_x: False
                            bar_width: 10
                            scroll_type: ['bars', 'content']
                            size_hint_y: None
                            ref_height: 200

                            BoxLayout:
                                size_hint_y: None
                                orientation: "vertical"
                                height: self.minimum_height

                                MetaInfo:
                                    id: exif_file_name
                                    key: "File Name"
                                BoxLayout:
                                    orientation: 'horizontal'
                                    size_hint_y: None
                                    ref_height: 20
                                    MetaKey:
                                        text: "Rating"
                                    HSpacer:
                                    RatingRow:
                                        id: exif_rating_row
                                        exif_pane: True
                                        ctx: root
                                        size_hint_x: None
                                        size_hint_y: None
                                        ref_width: 88
                                        ref_height: 20
                                MetaInfo:
                                    id: exif_file_size
                                    key: "File Size"
                                MetaInfo:
                                    id: exif_create_date
                                    key: "Create Date"
                                MetaInfo:
                                    id: exif_image_size
                                    key: "Image Size"
                                MetaInfo:
                                    id: exif_iso_speed
                                    key: "ISO"
                                MetaInfo:
                                    id: exif_aperture
                                    key: "Aperture"
                                MetaInfo:
                                    id: exif_shutter_speed
                                    key: "Shutter Speed"
                                MetaInfo:
                                    id: exif_exposure_compensation
                                    key: "Exposure Comp."
                                MetaInfo:
                                    id: exif_flash
                                    key: "Flash"
                                MetaInfo:
                                    id: exif_white_balance
                                    key: "White Balance"
                                MetaInfo:
                                    id: exif_focal_length
                                    key: "Focal Length"
                                MetaInfo:
                                    id: exif_exposure_program
                                    key: "Exposure Program"
                                MetaInfo:
                                    id: exif_make
                                    key: "Make"
                                MetaInfo:
                                    id: exif_model
                                    key: "Model"
                                MetaInfo:
                                    id: exif_lens_model
                                    key: "Lens Model"
                                MetaInfo:
                                    id: exif_software
                                    key: "Software"

                    CollapsibleBox:
                        id: masks_box
                        icon: "assets/Mask2Layer.png"
                        title: " Masks"
                        is_expanded: True
                        # Content will be added via python

                    CollapsibleBox:
                        id: presets_box
                        icon: "assets/Preset.png"
                        title: " Presets"
                        is_expanded: True
                        # Content will be added via python

                    CollapsibleBox:
                        id: history_box
                        icon: "assets/History.png"
                        title: " History"
                        is_expanded: True
                        # Content will be added via python
                            
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.55

                FloatLayout:
                    id: preview_widget
                    pos_hint: {'x':0, 'y': 0}
                    size_hint: 1.0, 0.95
                    on_touch_down: root.on_image_touch_down(args[1])
                    on_touch_move: root.on_image_touch_move(args[1])
                    on_touch_up: root.on_image_touch_up(args[1])

                    canvas.before:
                        # Black background for padding area
                        Color:
                            rgba: 0, 0, 0, 1
                        Rectangle:
                            pos: self.pos
                            size: self.size
                        
                        # Stencil Clip to Valid Content (Hide Reflect Padding)
                        StencilPush:
                        Rectangle:
                            pos: self.pos
                            size: self.size
                        StencilUse:
                        
                    canvas.after:
                        StencilUnUse:
                        Rectangle:
                            pos: self.pos
                            size: self.size
                        StencilPop:

                    Scatter:
                        id: transform_wrapper
                        auto_bring_to_front: False
                        do_rotation: False
                        do_scale: False
                        do_translation: False
                        size_hint: None, None
                        size: preview.size
                        center: self.parent.center

                        Image:
                            id: preview
                            size_hint: None, None
                            pos: 0, 0
                            size: self.texture_size

                            canvas:
                                Color:
                                    rgba: dark_color if not self.texture else clear_color
                                Rectangle:
                                    pos: self.pos
                                    size: self.size

                    MaskEditor2:
                        id: mask_editor2
                        root: root
                        pos_hint: {'x':0, 'top': 1}
                        canvas.before:
                            Color:
                                rgba: clear_color
                            Rectangle:
                                size: self.size
                                pos: self.pos

                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    ref_height: 30

                    Button:
                        size_hint_x: 0.1
                        text: "Select"
                        disabled: root.loading == True
                        on_press: root.on_select_press()
                    HSpacer:
                        size_hint_x: 0.5
                    ToggleButton:
                        id: mask2
                        size_hint_x: 0.1
                        text: "Mask2"
                        # image_loaded==False の間は loading==True の局面を内包するので loading 判定は不要。
                        # mask2_wait_full_load は RAW プレビュー〜フル復号間のみ True になる Mask2 専用 gate。
                        disabled: root.image_loaded == False or root.mask2_wait_full_load == True
                        on_state: root.on_mask2_press(self.state)
                        # マスク編集中も Geometry タブを開けるようにするため、Ge タブの disabled 強制は廃止。
                        # マスク Active 時は Ge タブの中身が「マスク Geometry」セットに切り替わる仕様。
                    HSpacer:
                        size_hint_x: 0.05
                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_x: 0.20
                        Image:
                            id: export_indicator
                            source: 'assets/box.gif'
                            anim_delay: 0.05
                            size_hint_x: None
                            ref_width: 30
                            pos_hint: {'center_y': 0.5}
                            opacity: 1 if root.export_in_progress else 0
                        Label:
                            text: (str(int(root.export_done)) + '/' + str(int(root.export_total))) if root.export_in_progress else ''
                            size_hint_x: 0.25
                            pos_hint: {'center_y': 0.5}
                            opacity: 1 if root.export_in_progress else 0
                            font_size: '13sp'
                            halign: 'right'
                            valign: 'middle'
                            text_size: self.size
                            color: 1, 1, 1, 1
                        Button:
                            text: 'Cancel' if root.export_in_progress else 'Export'
                            # image_loaded==False は loading==True を内包するので 1 条件で十分。
                            # Export 進行中は Cancel として常に有効。
                            disabled: root.image_loaded == False and not root.export_in_progress
                            size_hint_x: 0.8
                            on_press: root.on_export_bar_press()

            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.25

                BoxLayout:
                    orientation: 'horizontal'
                    size_hint: 1, None
                    ref_height: 30

                    Image:
                        id: processing_indicator
                        source: 'assets/box.gif'
                        anim_delay: 0.05
                        size_hint_x: None
                        ref_width: 30
                        opacity: 1 if root.is_processing else 0

                    HSpacer:
                        size_hint_x: 0.8
                    Button:
                        size_hint_x: None
                        ref_width: 60
                        ref_height: 15
                        font_size: '9pt'
                        text: "Reset"
                        disabled: root.image_loaded == False
                        on_press: root.begin_history_reset_all()
                        on_release:
                            root.reset_all()
                            root.end_history_reset_all()

                    ToggleButton:
                        id: preset
                        size_hint_x: None
                        ref_width: 60
                        ref_height: 15
                        font_size: '9pt'
                        text: "Preset"
                        disabled: root.image_loaded == False
                        #on_state: root.on_preset_press(self.state)


                TabbedPanel:
                    id: effects
                    do_default_tab: False
                    tab_width: self.width * 0.12
                    tab_height: self.height * 0.05
                    # image_loaded==False は loading==True を内包するので 1 条件で十分。
                    disabled: root.image_loaded == False
                    on_current_tab: root.on_current_tab(self.current_tab)
                    # マスク編集中も Ge タブを許可するため Ge 条件は外し、画像ロード/Mask2 待機の 2 条件のみで disabled を決定する
                    on_current_tab: mask2.disabled = root.image_loaded == False or root.mask2_wait_full_load == True

                    IconTabbedPanelItem:
                        text: 'Ba'
                        icon_source: 'assets/Basic.png'

                        ScrollView:
                            bar_width: 10
                            scroll_type: ['bars', 'content']

                            MDBoxLayout:
                                orientation: "vertical"
                                size_hint_y: None
                                height: self.minimum_height
                                md_bg_color: dark_color
                                ref_padding: 4

                                HeadLabel:
                                    id: switch_white_balance
                                    text: ' White Balance'
                                    on_press: root.begin_history_effect_ctrl(2, 'color_temperature')
                                    on_active: root.apply_effects_lv(2, 'color_temperature')
                                    on_release: root.end_history_effect_ctrl(2, 'color_temperature')

                                ParamSlider:
                                    id: slider_color_temperature
                                    text: "Temperature"
                                    min: 2000
                                    max: 12000
                                    value: 5000
                                    step: 10
                                    bar_renderer: "color_temperature"
                                    bar_saturation: 2.4
                                    bar_show_active_overlay: False
                                    bar_show_anchor_marker: True
                                    on_slider: root.apply_effects_lv(2, 'color_temperature')
                                    on_before_edit: root.begin_history_effect_ctrl(2, 'color_temperature')
                                    on_after_edit: root.end_history_effect_ctrl(2, 'color_temperature')

                                ParamSlider:
                                    id: slider_color_tint
                                    text: "Tint"
                                    min: -100
                                    max: 100
                                    value: 0
                                    step: 1
                                    bar_renderer: "color_tint"
                                    bar_saturation: 2.4
                                    bar_show_active_overlay: False
                                    bar_show_anchor_marker: True
                                    on_slider: root.apply_effects_lv(2, 'color_temperature')
                                    on_before_edit: root.begin_history_effect_ctrl(2, 'color_temperature')
                                    on_after_edit: root.end_history_effect_ctrl(2, 'color_temperature')

                                VSeparator:

                                HeadLabel:
                                    id: switch_exposure_contrast
                                    text: ' Exposure & Contrast'
                                    on_press: root.begin_history_effect_ctrl(2, ['exposure', 'contrast'])
                                    on_active: root.apply_effects_lv(2, ['exposure', 'contrast'])
                                    on_release: root.end_history_effect_ctrl(2, ['exposure', 'contrast'])

                                ParamSlider:
                                    id: slider_exposure
                                    text: "Exposure"                            
                                    min: -4.0
                                    max: 4.0
                                    value: 0.0
                                    step: 0.05
                                    for_float: True
                                    on_slider: root.apply_effects_lv(2, 'exposure')
                                    on_before_edit: root.begin_history_effect_ctrl(2, 'exposure')
                                    on_after_edit: root.end_history_effect_ctrl(2, 'exposure')

                                ParamSlider:
                                    id: slider_contrast
                                    text: "Contrast"
                                    min: -100
                                    max: 100
                                    value: 0
                                    step: 1
                                    on_slider: root.apply_effects_lv(2, 'contrast')
                                    on_before_edit: root.begin_history_effect_ctrl(2, 'contrast')
                                    on_after_edit: root.end_history_effect_ctrl(2, 'contrast')

                                VSeparator:

                                HeadLabel:
                                    id: switch_tone
                                    text: ' Tone'
                                    on_press: root.begin_history_effect_ctrl(2, 'tone')
                                    on_active: root.apply_effects_lv(2, 'tone')
                                    on_release: root.end_history_effect_ctrl(2, 'tone')

                                ParamSlider:
                                    id: slider_highlight
                                    text: "Highlights"
                                    min: -100
                                    max: 100
                                    value: 0
                                    step: 1
                                    on_slider: root.apply_effects_lv(2, 'tone')
                                    on_before_edit: root.begin_history_effect_ctrl(2, 'tone')
                                    on_after_edit: root.end_history_effect_ctrl(2, 'tone')

                                ParamSlider:
                                    id: slider_shadow
                                    text: "Shadows"
                                    min: -100
                                    max: 100
                                    value: 0
                                    step: 1
                                    on_slider: root.apply_effects_lv(2, 'tone')
                                    on_before_edit: root.begin_history_effect_ctrl(2, 'tone')
                                    on_after_edit: root.end_history_effect_ctrl(2, 'tone')

                                ParamSlider:
                                    id: slider_midtone
                                    text: "Midtone"                            
                                    min: -100
                                    max: 100
                                    value: 0
                                    step: 1
                                    on_slider: root.apply_effects_lv(2, 'tone')
                                    on_before_edit: root.begin_history_effect_ctrl(2, 'tone')
                                    on_after_edit: root.end_history_effect_ctrl(2, 'tone')

                                ParamSlider:
                                    id: slider_white
                                    text: "White"
                                    min: -100
                                    max: 100
                                    value: 0
                                    step: 1
                                    on_slider: root.apply_effects_lv(2, 'tone')
                                    on_before_edit: root.begin_history_effect_ctrl(2, 'tone')
                                    on_after_edit: root.end_history_effect_ctrl(2, 'tone')

                                ParamSlider:
                                    id: slider_black
                                    text: "Black"
                                    min: -100
                                    max: 100
                                    value: 0
                                    step: 1
                                    on_slider: root.apply_effects_lv(2, 'tone')
                                    on_before_edit: root.begin_history_effect_ctrl(2, 'tone')
                                    on_after_edit: root.end_history_effect_ctrl(2, 'tone')

                                VSeparator:

                                HeadLabel:
                                    id: switch_level
                                    text: ' Level'
                                    on_press: root.begin_history_effect_ctrl(2, 'level')
                                    on_active: root.apply_effects_lv(2, 'level')
                                    on_release: root.end_history_effect_ctrl(2, 'level')

                                ParamSlider:
                                    id: slider_black_level
                                    text: "Black Level"
                                    min: 0
                                    max: 253
                                    value: 0
                                    for_float: True
                                    step: 0.1
                                    on_slider: root.apply_effects_lv(2, 'level')
                                    on_before_edit: root.begin_history_effect_ctrl(2, 'level')
                                    on_after_edit: root.end_history_effect_ctrl(2, 'level')

                                ParamSlider:
                                    id: slider_mid_level
                                    text: "Mid Level"
                                    min: 1
                                    max: 254
                                    value: 127
                                    for_float: True
                                    step: 0.1
                                    on_slider: root.apply_effects_lv(2, 'level')
                                    on_before_edit: root.begin_history_effect_ctrl(2, 'level')
                                    on_after_edit: root.end_history_effect_ctrl(2, 'level')

                                ParamSlider:
                                    id: slider_white_level
                                    text: "White Level"
                                    min: 2
                                    max: 255
                                    value: 255
                                    for_float: True
                                    step: 0.1
                                    on_slider: root.apply_effects_lv(2, 'level')
                                    on_before_edit: root.begin_history_effect_ctrl(2, 'level')
                                    on_after_edit: root.end_history_effect_ctrl(2, 'level')

                                VSeparator:
                                
                                HeadLabel:
                                    id: switch_precence
                                    text: ' Precence'
                                    on_press: root.begin_history_effect_ctrl(2, ['clarity', 'texture', 'microcontrast', 'dehaze', 'clahe'])
                                    on_active: root.apply_effects_lv(2, ['clarity', 'texture', 'microcontrast', 'dehaze', 'clahe'])
                                    on_release: root.end_history_effect_ctrl(2, ['clarity', 'texture', 'microcontrast', 'dehaze', 'clahe'])

                                ParamSlider:
                                    id: slider_clarity
                                    text: "Clarity"
                                    min: -100
                                    max: 100
                                    value: 0
                                    step: 1
                                    on_slider: root.apply_effects_lv(2, 'clarity')
                                    on_before_edit: root.begin_history_effect_ctrl(2, 'clarity')
                                    on_after_edit: root.end_history_effect_ctrl(2, 'clarity')

                                ParamSlider:
                                    id: slider_texture
                                    text: "Texture"
                                    min: -100
                                    max: 100
                                    value: 0
                                    step: 1
                                    on_slider: root.apply_effects_lv(2, 'texture')
                                    on_before_edit: root.begin_history_effect_ctrl(2, 'texture')
                                    on_after_edit: root.end_history_effect_ctrl(2, 'texture')

                                ParamSlider:
                                    id: slider_microcontrast
                                    text: "Micro Contrast"
                                    min: -100
                                    max: 100
                                    value: 0
                                    step: 1
                                    on_slider: root.apply_effects_lv(2, 'microcontrast')
                                    on_before_edit: root.begin_history_effect_ctrl(2, 'microcontrast')
                                    on_after_edit: root.end_history_effect_ctrl(2, 'microcontrast')

                                ParamSlider:
                                    id: slider_dehaze
                                    text: "Dehaze"
                                    min: -100
                                    max: 100
                                    value: 0
                                    step: 1
                                    on_slider: root.apply_effects_lv(2, 'dehaze')
                                    on_before_edit: root.begin_history_effect_ctrl(2, 'dehaze')
                                    on_after_edit: root.end_history_effect_ctrl(2, 'dehaze')

                                ParamSlider:
                                    id: slider_clahe
                                    text: "CLAHE"
                                    min: 0
                                    max: 100
                                    value: 0
                                    step: 1
                                    on_slider: root.apply_effects_lv(2, 'clahe')
                                    on_before_edit: root.begin_history_effect_ctrl(2, 'clahe')
                                    on_after_edit: root.end_history_effect_ctrl(2, 'clahe')

                                VSeparator:

                                HeadLabel:
                                    id: switch_saturation
                                    text: ' Saturation'
                                    on_press: root.begin_history_effect_ctrl(2, 'vs_and_saturation', 'saturation')
                                    on_active: root.apply_effects_lv(2, 'vs_and_saturation')
                                    on_release: root.end_history_effect_ctrl(2, 'vs_and_saturation', 'saturation')
                                
                                ParamSlider:
                                    text: "Saturation"
                                    id: slider_saturation
                                    min: -100
                                    max: 100
                                    value: 0
                                    step: 1
                                    on_slider: root.apply_effects_lv(2, 'vs_and_saturation')
                                    on_before_edit: root.begin_history_effect_ctrl(2, 'vs_and_saturation', 'saturation')
                                    on_after_edit: root.end_history_effect_ctrl(2, 'vs_and_saturation', 'saturation')

                                ParamSlider:
                                    text: "Vibrance"
                                    id: slider_vibrance
                                    min: -100
                                    max: 100
                                    value: 0
                                    step: 1
                                    on_slider: root.apply_effects_lv(2, 'vs_and_saturation')
                                    on_before_edit: root.begin_history_effect_ctrl(2, 'vs_and_saturation', 'saturation')
                                    on_after_edit: root.end_history_effect_ctrl(2, 'vs_and_saturation', 'saturation')

                                VSeparator:
                                                            
                                HeadLabel:
                                    id: switch_color_mixer
                                    text: ' Color Mixer'
