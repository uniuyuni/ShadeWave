                                        pos_hint: {'center_x': .5, 'center_y': .5}
                                        ref_height: 20
                                        text: "Lens"
                                        group: 'distortion'
                                        state: 'normal'
                                        on_press: root.apply_effects_lv(0, "geometry")
                                    ToggleButton:
                                        id: btn_trapezoid
                                        pos_hint: {'center_x': .5, 'center_y': .5}
                                        ref_height: 20
                                        text: "Trapezoid"
